#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""pj — manage periodic launchd jobs that run `claude -p` (and friends).

Schedule parsing, plist/wrapper rendering and TOML live in pjkit.py next to
this file and are unit-tested. This file is the CLI plus the launchd /
filesystem / interactive I/O around it.
"""
import argparse
import os
import shlex
import shutil
import subprocess
import sys
from pathlib import Path

_SELF = Path(__file__).resolve()  # follows a ~/bin/pj symlink into the checkout
sys.path.insert(0, str(_SELF.parent))  # pjkit.py lives next to this script
import pjkit  # noqa: E402

# Where jobs live. Point PJ_JOBS_DIR at a tracked dir (e.g. your dotfiles) to
# version-control them; defaults to ~/.pj/jobs otherwise.
JOBS_DIR = Path(os.environ.get("PJ_JOBS_DIR", Path.home() / ".pj" / "jobs")).expanduser()
DOMAIN = f"gui/{os.getuid()}"


# --------------------------------------------------------------------------
# terminal helpers
# --------------------------------------------------------------------------
def _c(code, text):
    return f"\033[{code}m{text}\033[0m" if sys.stdout.isatty() else text


def bold(s):
    return _c("1", s)


def dim(s):
    return _c("2", s)


def red(s):
    return _c("31", s)


def green(s):
    return _c("32", s)


def yellow(s):
    return _c("33", s)


def info(msg):
    print(msg)


def die(msg, code=1):
    print(red(f"pj: {msg}") if code else msg, file=sys.stderr if code else sys.stdout)
    sys.exit(code)


# --------------------------------------------------------------------------
# launchctl
# --------------------------------------------------------------------------
def launchctl(*args):
    return subprocess.run(["launchctl", *args], capture_output=True, text=True)


def is_loaded(label):
    return launchctl("print", f"{DOMAIN}/{label}").returncode == 0


def bootout(label):
    launchctl("bootout", f"{DOMAIN}/{label}")  # ignore errors: may not be loaded


def bootstrap(plist):
    r = launchctl("bootstrap", DOMAIN, str(plist))
    if r.returncode != 0:
        die(f"launchctl bootstrap failed: {(r.stderr or r.stdout).strip()}")


def reload_job(plist, label):
    bootout(label)
    bootstrap(plist)


def last_exit(label):
    r = launchctl("print", f"{DOMAIN}/{label}")
    if r.returncode != 0:
        return None
    for line in r.stdout.splitlines():
        s = line.strip()
        if s.startswith("last exit code ="):
            return s.split("=", 1)[1].strip()
    return None


# --------------------------------------------------------------------------
# job persistence
# --------------------------------------------------------------------------
def _is_generated(path):
    """A generated file carries the pj marker. Removing it = the user adopted
    the file, so pj should leave it alone. Absent/unreadable -> safe to write."""
    try:
        return "generated by pj" in path.read_text().lower()
    except OSError:
        return True


def _write_toml(manifest):
    paths = pjkit.job_paths(JOBS_DIR, manifest["name"])
    paths.dir.mkdir(parents=True, exist_ok=True)
    paths.toml.write_text(pjkit.dump_toml(manifest))
    return paths


def write_artifacts(manifest, *, regen_wrapper=False, force_plist=False):
    """(Re)generate wrapper.sh and the plist from the manifest.

    job.toml is the source of truth: both files regenerate from it unless you
    deleted their pj marker (adopted them). --regen-wrapper / --force override.
    """
    name = manifest["name"]
    paths = pjkit.job_paths(JOBS_DIR, name)
    paths.log_out.parent.mkdir(parents=True, exist_ok=True)

    if regen_wrapper or _is_generated(paths.wrapper):
        paths.wrapper.write_text(
            pjkit.render_wrapper(manifest["working_dir"], manifest["command"])
        )
        paths.wrapper.chmod(0o755)
    else:
        info(dim("  kept your customized wrapper.sh (--regen-wrapper to rebuild)"))

    label = pjkit.build_label(name)
    if force_plist or _is_generated(paths.plist):
        keys = pjkit.schedule_to_launchd(manifest["schedule"])
        paths.plist.write_text(
            pjkit.render_plist(label, paths.wrapper, keys, paths.log_out, paths.log_err)
        )
    else:
        info(yellow("  kept your adopted plist; job.toml schedule edits need --force"))
    return paths, label


def load_job(name):
    paths = pjkit.job_paths(JOBS_DIR, name)
    if not paths.toml.exists():
        die(f"no such job: {name!r} (looked in {paths.toml})")
    return pjkit.load_toml(paths.toml.read_text()), paths


def all_jobs():
    return sorted(JOBS_DIR.glob("*/job.toml"))


def _warn_if_missing_dir(working_dir):
    if not os.path.isdir(working_dir):
        info(yellow(f"  ! working dir does not exist yet: {working_dir}"))


def apply_job(name, *, regen_wrapper=False, force=False):
    manifest, paths = load_job(name)
    try:
        pjkit.schedule_to_launchd(manifest["schedule"])  # validate before writing
    except pjkit.JobSpecError as e:
        die(f"job.toml invalid: {e}")
    paths, label = write_artifacts(manifest, regen_wrapper=regen_wrapper, force_plist=force)
    if manifest.get("enabled", True):
        reload_job(paths.plist, label)
        info(green(f"applied + reloaded {label} ({pjkit.human_schedule(manifest['schedule'])})"))
    else:
        bootout(label)
        info(dim("applied; job is disabled (not loaded)."))


# --------------------------------------------------------------------------
# interactive wizard
# --------------------------------------------------------------------------
def ask(prompt, default=None, help=None, validate=None, transform=None):
    while True:
        if help:
            print(dim(f"  {help}"))
        suffix = f" [{default}]" if default not in (None, "") else ""
        try:
            raw = input(f"{bold(prompt)}{suffix}: ").strip()
        except EOFError:
            die("aborted", 0)
        if not raw and default is not None:
            raw = default
        if transform:
            raw = transform(raw)
        if validate:
            try:
                return validate(raw)
            except pjkit.JobSpecError as e:
                print(red(f"  ! {e}"))
                continue
        return raw


def ask_bool(prompt, default=True):
    hint = "Y/n" if default else "y/N"
    while True:
        try:
            raw = input(f"{bold(prompt)} [{hint}]: ").strip().lower()
        except EOFError:
            die("aborted", 0)
        if not raw:
            return default
        if raw in ("y", "yes"):
            return True
        if raw in ("n", "no"):
            return False
        print(red("  ! please answer y or n"))


def ask_choice(prompt, options):
    print(bold(prompt))
    for i, (label, _) in enumerate(options, 1):
        print(f"  {i}) {label}")
    while True:
        try:
            raw = input(f"Choose 1-{len(options)}: ").strip()
        except EOFError:
            die("aborted", 0)
        if raw.isdigit() and 1 <= int(raw) <= len(options):
            return options[int(raw) - 1][1]
        print(red("  ! enter a number from the list"))


def _validate_new_name(s):
    name = pjkit.validate_name(s)
    if pjkit.job_paths(JOBS_DIR, name).toml.exists():
        raise pjkit.JobSpecError(f"job {name!r} already exists")
    return name


def _nonempty(s):
    if not s.strip():
        raise pjkit.JobSpecError("cannot be empty")
    return s


def _wizard_schedule():
    choice = ask_choice(
        "How often should it run?",
        [
            ("Every day at a set time", "daily"),
            ("Specific weekdays at a set time", "weekly"),
            ("Every N minutes / hours", "interval"),
        ],
    )
    while True:
        try:
            if choice == "interval":
                every = ask("Interval", help="e.g. 30m, 2h, 90s")
                return pjkit.build_interval_schedule(every)
            times = ask("Time(s)", help="24h HH:MM; comma-separate several, e.g. 09:00,18:30")
            time_list = [t.strip() for t in times.split(",") if t.strip()]
            if choice == "weekly":
                days = ask("Weekdays", help="e.g. mon,wed,fri")
                return pjkit.build_calendar_schedule(time_list, days=days)
            return pjkit.build_calendar_schedule(time_list)
        except pjkit.JobSpecError as e:
            print(red(f"  ! {e}"))


def _print_summary(manifest):
    print(bold("\nSummary"))
    print(f"  name        {manifest['name']}")
    if manifest["description"]:
        print(f"  description {manifest['description']}")
    print(f"  directory   {manifest['working_dir']}")
    print(f"  command     {manifest['command']}")
    print(f"  schedule    {pjkit.human_schedule(manifest['schedule'])}")


def run_wizard():
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        die(
            "`pj add` with no arguments needs an interactive terminal.\n"
            "Pass flags instead, e.g. pj add NAME --at 09:00 --cd DIR --run '...'"
        )
    print(bold("New periodic job") + dim("  (ctrl-c to abort)"))
    name = ask(
        "Name",
        help="lowercase letters/digits/-/_ ; used for the folder & launchd label",
        validate=_validate_new_name,
    )
    description = ask("Description", default="", help="optional; shown in `pj list`/`show`")
    working_dir = ask(
        "Working directory",
        default=os.getcwd(),
        help="the trusted folder the job cd's into (its .claude/skills load there)",
        transform=lambda s: os.path.abspath(os.path.expanduser(s)),
    )
    if not os.path.isdir(working_dir):
        print(yellow(f"  ! {working_dir} doesn't exist yet — ok, but make sure it will."))
    print(dim("  Tip: for unattended runs use a non-interactive permission mode, e.g."))
    print(dim('       claude -p "..." --permission-mode dontAsk'))
    command = ask("Command to run", help="full shell command; runs with your full zsh env", validate=_nonempty)
    schedule = _wizard_schedule()
    schedule["run_at_load"] = ask_bool(
        "Also run once immediately each time it loads (e.g. at login)?", default=False
    )
    enable_now = ask_bool("Load it now so it runs on schedule?", default=True)
    manifest = {
        "name": name,
        "description": description,
        "working_dir": working_dir,
        "command": command,
        "enabled": enable_now,
        "schedule": schedule,
    }
    _print_summary(manifest)
    if not ask_bool("Create this job?", default=True):
        die("aborted", 0)
    return manifest, enable_now


# --------------------------------------------------------------------------
# commands
# --------------------------------------------------------------------------
def manifest_from_flags(args):
    try:
        name = pjkit.validate_name(args.name)
        if bool(args.at) == bool(args.every):
            die("specify exactly one of --at (one or more) or --every")
        if args.every:
            schedule = pjkit.build_interval_schedule(args.every, run_at_load=args.run_at_load)
        else:
            schedule = pjkit.build_calendar_schedule(
                args.at, days=args.days, run_at_load=args.run_at_load
            )
    except pjkit.JobSpecError as e:
        die(str(e))
    if not args.cd:
        die("--cd DIR is required")
    if not args.run:
        die("--run 'COMMAND' is required")
    working_dir = os.path.abspath(os.path.expanduser(args.cd))
    manifest = {
        "name": name,
        "description": args.desc or "",
        "working_dir": working_dir,
        "command": args.run,
        "enabled": not args.disabled,
        "schedule": schedule,
    }
    return manifest, (not args.disabled)


def cmd_add(args):
    if args.interactive or not args.name:
        manifest, enable_now = run_wizard()
    else:
        manifest, enable_now = manifest_from_flags(args)

    if pjkit.job_paths(JOBS_DIR, manifest["name"]).toml.exists():
        die(f"job {manifest['name']!r} already exists. Use `pj edit` / `pj apply`.")

    _write_toml(manifest)
    paths, label = write_artifacts(manifest)
    info(green(f"created {paths.dir}"))
    if enable_now:
        reload_job(paths.plist, label)
        info(green(f"loaded {label} ({pjkit.human_schedule(manifest['schedule'])})"))
    else:
        info(dim(f"not loaded. `pj enable {manifest['name']}` to start it."))
    _warn_if_missing_dir(manifest["working_dir"])


def _col_widths(headers, rows):
    cols = list(zip(*([headers] + rows))) if rows else [(h,) for h in headers]
    return [max(len(str(c)) for c in col) for col in cols]


def cmd_list(args):
    jobs = all_jobs()
    if not jobs:
        info(dim("no jobs yet. `pj add` to create one."))
        return
    headers = ("NAME", "SCHEDULE", "ENABLED", "LAUNCHD", "LAST EXIT")
    rows = []
    for toml_path in jobs:
        name = toml_path.parent.name
        m = pjkit.load_toml(toml_path.read_text())
        label = pjkit.build_label(name)
        rows.append(
            (
                name,
                pjkit.human_schedule(m["schedule"]),
                "on" if m.get("enabled") else "off",
                "loaded" if is_loaded(label) else "-",
                last_exit(label) or "-",
            )
        )
    widths = _col_widths(headers, rows)
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(bold(fmt.format(*headers)))
    for row in rows:
        print(fmt.format(*row))


def _tail(path, n):
    if not path.exists() or path.stat().st_size == 0:
        print(dim("  (no log yet)"))
        return
    for line in path.read_text(errors="replace").splitlines()[-n:]:
        print("  " + line)


def cmd_show(args):
    m, paths = load_job(args.name)
    label = pjkit.build_label(args.name)
    print(bold(args.name) + dim(f"  [{label}]"))
    if m.get("description"):
        print(f"  {m['description']}")
    print(f"  schedule : {pjkit.human_schedule(m['schedule'])}")
    print(f"  command  : {m['command']}")
    print(f"  dir      : {m['working_dir']}")
    print(f"  enabled  : {m.get('enabled')}    launchd: {'loaded' if is_loaded(label) else 'not loaded'}")
    print(f"  files    : {paths.dir}")
    print(bold("\n  recent stdout:"))
    _tail(paths.log_out, args.lines)
    print(bold("  recent stderr:"))
    _tail(paths.log_err, args.lines)


def cmd_edit(args):
    _, paths = load_job(args.name)
    editor = os.environ.get("EDITOR", "vim")
    subprocess.run([*shlex.split(editor), str(paths.toml)])
    apply_job(args.name)


def cmd_edit_wrapper(args):
    _, paths = load_job(args.name)
    editor = os.environ.get("EDITOR", "vim")
    subprocess.run([*shlex.split(editor), str(paths.wrapper)])
    info(dim("wrapper saved; takes effect on the next run (no reload needed)."))


def cmd_apply(args):
    apply_job(args.name, regen_wrapper=args.regen_wrapper, force=args.force)


def cmd_enable(args):
    m, _ = load_job(args.name)
    m["enabled"] = True
    _write_toml(m)
    paths, label = write_artifacts(m)
    reload_job(paths.plist, label)
    info(green(f"enabled + loaded {label}"))


def cmd_disable(args):
    m, _ = load_job(args.name)
    m["enabled"] = False
    _write_toml(m)
    bootout(pjkit.build_label(args.name))
    info(yellow(f"disabled {args.name} (unloaded; files kept)"))


def cmd_run(args):
    load_job(args.name)
    label = pjkit.build_label(args.name)
    if not is_loaded(label):
        die(f"{args.name} is not loaded; `pj enable {args.name}` first.")
    r = launchctl("kickstart", "-k", f"{DOMAIN}/{label}")
    if r.returncode != 0:
        die(f"kickstart failed: {(r.stderr or r.stdout).strip()}")
    info(green(f"kicked off {label}; see `pj logs {args.name}`"))


def cmd_logs(args):
    _, paths = load_job(args.name)
    if args.follow:
        os.execvp("tail", ["tail", "-n", str(args.lines), "-F", str(paths.log_out), str(paths.log_err)])
    print(bold(f"── stdout: {paths.log_out}"))
    _tail(paths.log_out, args.lines)
    print(bold(f"── stderr: {paths.log_err}"))
    _tail(paths.log_err, args.lines)


def cmd_status(args):
    label = pjkit.build_label(args.name)
    r = launchctl("print", f"{DOMAIN}/{label}")
    if r.returncode != 0:
        info(yellow(f"{args.name}: not loaded"))
        return
    wanted = ("state", "last exit code", "pid", "runs", "program ")
    for line in r.stdout.splitlines():
        s = line.strip()
        if any(s.startswith(w) for w in wanted):
            print("  " + s)


def cmd_rm(args):
    _, paths = load_job(args.name)
    if not args.force:
        try:
            ans = input(f"remove job {args.name!r} and folder {paths.dir}? [y/N] ").strip().lower()
        except EOFError:
            ans = "n"
        if ans not in ("y", "yes"):
            die("aborted", 0)
    bootout(pjkit.build_label(args.name))
    shutil.rmtree(paths.dir)
    info(green(f"removed {args.name}"))


def _check(label, ok, detail=""):
    mark = green("✓") if ok else red("✗")
    return f"  {mark} {label}" + (dim(f"  ({detail})") if detail else "")


def cmd_doctor(args):
    print(bold("pj doctor"))
    r = subprocess.run(["/bin/zsh", "-i", "-c", "command -v claude"], capture_output=True, text=True)
    print(_check("claude reachable in job env (zsh -i)", r.returncode == 0, r.stdout.strip()))
    creds = Path.home() / ".claude" / ".credentials.json"
    print(_check("claude credentials present", creds.exists(), str(creds)))
    print(_check("jobs dir exists", JOBS_DIR.exists(), str(JOBS_DIR)))
    print(_check("launchd gui domain reachable", launchctl("print", DOMAIN).returncode == 0, DOMAIN))
    print(_check("uv available", shutil.which("uv") is not None, shutil.which("uv") or "not found"))


# --------------------------------------------------------------------------
# argument parsing
# --------------------------------------------------------------------------
def build_parser():
    p = argparse.ArgumentParser(prog="pj", description="Periodic launchd jobs for claude -p and friends.")
    sub = p.add_subparsers(dest="cmd")

    a = sub.add_parser("add", help="add a job (no args / -i launches an interactive wizard)")
    a.add_argument("name", nargs="?", help="job name (omit for the wizard)")
    a.add_argument("-i", "--interactive", action="store_true", help="force the interactive wizard")
    a.add_argument("--at", action="append", metavar="HH:MM", help="time of day (repeatable; 'mon,fri 18:00' allowed)")
    a.add_argument("--every", metavar="N[smh]", help="interval, e.g. 30m, 2h")
    a.add_argument("--days", metavar="mon,fri", help="restrict --at to weekdays")
    a.add_argument("--cd", metavar="DIR", help="working directory the job runs in")
    a.add_argument("--run", metavar="CMD", help="command to run")
    a.add_argument("--desc", metavar="TEXT", help="description")
    a.add_argument("--run-at-load", action="store_true", help="also run once when (re)loaded")
    a.add_argument("--disabled", action="store_true", help="create but don't load yet")
    a.set_defaults(func=cmd_add)

    for name, fn, help in [
        ("list", cmd_list, "list all jobs"),
        ("doctor", cmd_doctor, "check the environment is ready for unattended runs"),
    ]:
        sp = sub.add_parser(name, help=help)
        sp.set_defaults(func=fn)

    def with_name(name, fn, help, extra=None):
        sp = sub.add_parser(name, help=help)
        sp.add_argument("name", help="job name")
        if extra:
            extra(sp)
        sp.set_defaults(func=fn)

    with_name("show", cmd_show, "show a job's config and recent logs",
              lambda sp: sp.add_argument("-n", "--lines", type=int, default=10, help="log lines"))
    with_name("edit", cmd_edit, "edit job.toml in $EDITOR, then apply")
    with_name("edit-wrapper", cmd_edit_wrapper, "edit the job's wrapper.sh in $EDITOR")
    def _apply_flags(sp):
        sp.add_argument("--regen-wrapper", action="store_true", help="also rebuild an adopted wrapper.sh")
        sp.add_argument("--force", action="store_true", help="overwrite an adopted plist")

    with_name("apply", cmd_apply, "regenerate wrapper+plist from job.toml and reload", _apply_flags)
    with_name("enable", cmd_enable, "load the job into launchd")
    with_name("disable", cmd_disable, "unload the job (keep files)")
    with_name("run", cmd_run, "run the job now")
    with_name("status", cmd_status, "show launchd status")
    with_name("rm", cmd_rm, "remove a job and its folder",
              lambda sp: sp.add_argument("-f", "--force", action="store_true", help="don't prompt"))
    with_name("logs", cmd_logs, "tail the job's stdout+stderr logs",
              lambda sp: (sp.add_argument("-f", "--follow", action="store_true", help="follow"),
                          sp.add_argument("-n", "--lines", type=int, default=20, help="lines")))
    return p


def main():
    parser = build_parser()
    args = parser.parse_args()
    if not getattr(args, "func", None):
        parser.print_help()
        sys.exit(0)
    args.func(args)


if __name__ == "__main__":
    main()
